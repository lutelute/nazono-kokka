# Auto Claude data directory
.auto-claude/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
*.egg

# Virtual environments
.venv/
venv/

# ChromaDB (local vector store)
chroma_db/

# Vector visualization projection cache (regenerated by `python -m rag_system.vector_analysis precompute`)
.viz_cache/

# Comparison results (generated at runtime)
test_cases/results/*.json

# Saved configuration presets (generated at runtime)
test_cases/saved_configs.json

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Auto Claude generated files
.auto-claude-security.json
.auto-claude-status
.claude_settings.json
.worktrees/
.security-key
logs/security/

# Runtime logs (e.g. streamlit.log)
logs/*.log

# Local scratch artifacts (Playwright captures, screenshots, throwaway demos)
.playwright-mcp/
/highlight_demo.html
/line_report.png
/tool_view.png

# Claude Code セッション引き継ぎ（個人作業記録）
.claude/
